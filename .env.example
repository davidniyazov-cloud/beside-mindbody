# ─── Mindbody ────────────────────────────────────────────────
MINDBODY_API_KEY=your_api_key_here
MINDBODY_SITE_ID=38315
MINDBODY_STAFF_USERNAME=your_staff_username
MINDBODY_STAFF_PASSWORD=your_staff_password

# ─── Beside ──────────────────────────────────────────────────
# Secret token Beside will send in the webhook header (set this in Beside settings)
BESIDE_WEBHOOK_SECRET=choose_a_secret_token_here

# ─── Server ──────────────────────────────────────────────────
PORT=3000

# ─── Default booking settings ────────────────────────────────
# Default staff member ID to assign appointments to (your Mindbody staff ID)
DEFAULT_STAFF_ID=100000001
# Default service/session type ID for a 1-hour massage
DEFAULT_SERVICE_ID=1
